#!name=FUTU + Longbridge Trading Rules
#!desc=Production grade broker routing (FUTU + Longbridge)
#!author=Bryan

[Rule]

# =========================
# FUTU / MOOMOO
# =========================

DOMAIN-SUFFIX,futunn.com,PROXY
DOMAIN-SUFFIX,moomoo.com,PROXY
DOMAIN-SUFFIX,futuhk.com,PROXY
DOMAIN-SUFFIX,futuholdings.com,PROXY
DOMAIN-SUFFIX,futu.com,PROXY
DOMAIN-SUFFIX,futuinc.com,PROXY
DOMAIN-SUFFIX,futuniuniu.com,PROXY
DOMAIN-SUFFIX,futufin.com,PROXY
DOMAIN-SUFFIX,futubull.com,PROXY
DOMAIN-SUFFIX,futubull.cn,PROXY
DOMAIN-SUFFIX,futu.link,PROXY

DOMAIN-SUFFIX,cdn.futustatic.com,PROXY


# =========================
# LONGBRIDGE
# =========================

DOMAIN-SUFFIX,longbridge.com,PROXY
DOMAIN-SUFFIX,longbridgeapp.com,PROXY
DOMAIN-SUFFIX,longbridge.sg,PROXY
DOMAIN-SUFFIX,longbridgehk.com,PROXY
DOMAIN-SUFFIX,lbkrs.com,PROXY

DOMAIN,quote.longbridge.global,PROXY


# =========================
# MARKET DATA
# =========================

DOMAIN-SUFFIX,tradingview.com,PROXY
DOMAIN-SUFFIX,polygon.io,PROXY
DOMAIN-SUFFIX,nasdaq.com,PROXY
DOMAIN-SUFFIX,bloomberg.com,PROXY
DOMAIN-SUFFIX,wsj.com,PROXY


# =========================
# PUSH / REALTIME
# =========================

DOMAIN-SUFFIX,pusher.com,PROXY
DOMAIN-SUFFIX,pusherapp.com,PROXY


# =========================
# DNS / HTTPS RESOLVER
# =========================

DOMAIN-SUFFIX,doh.pub,PROXY
DOMAIN-SUFFIX,dns.google,PROXY
DOMAIN-SUFFIX,cloudflare-dns.com,PROXY


# =========================
# SYSTEM SAFETY
# =========================

IP-CIDR,17.0.0.0/8,DIRECT,no-resolve
